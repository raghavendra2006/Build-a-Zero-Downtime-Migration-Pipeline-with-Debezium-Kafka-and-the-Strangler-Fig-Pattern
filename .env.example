# =============================================================================
# Zero-Downtime Migration Pipeline — Environment Variables
# =============================================================================
# Copy this file to .env and modify values as needed.
# All variables have sensible defaults in docker-compose.yml.

# -----------------------------------------------------------------------------
# PostgreSQL Configuration (shared by legacy_db and micro_db)
# -----------------------------------------------------------------------------
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres

# -----------------------------------------------------------------------------
# Kafka Configuration
# -----------------------------------------------------------------------------
KAFKA_BROKER=kafka:9092

# -----------------------------------------------------------------------------
# CDC Consumer Configuration
# -----------------------------------------------------------------------------
KAFKA_TOPIC=legacyserver.public.orders
KAFKA_GROUP_ID=cdc-consumer-group
OUTPUT_FILE=/output/cdc_events.jsonl

# -----------------------------------------------------------------------------
# Legacy Database (for CDC Consumer row count queries)
# -----------------------------------------------------------------------------
LEGACY_DB_HOST=legacy_db
LEGACY_DB_PORT=5432
LEGACY_DB_USER=postgres
LEGACY_DB_PASSWORD=postgres
LEGACY_DB_NAME=postgres

# -----------------------------------------------------------------------------
# Gateway Configuration
# -----------------------------------------------------------------------------
LEGACY_SERVICE_URL=http://legacy_service:8081
MICRO_SERVICE_URL=http://micro_service:8082
METRICS_OUTPUT_FILE=/output/metrics_snapshot.json
ROLLBACK_LOG_FILE=/output/rollback_log.jsonl
DUAL_WRITE_TIMEOUT_MS=500
LATENCY_WINDOW_SIZE=1000
